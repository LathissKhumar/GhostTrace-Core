# GhostTrace Environment Configuration
# Copy this file to .env and fill in the values.
# All variables are optional unless marked [REQUIRED].

# =============================================================================
# LLM PROVIDER
# =============================================================================

# Which LLM provider to use: "groq" (free), "anthropic" (paid), or "ollama" (local)
# Default: groq
LLM_PROVIDER=groq

# --- Groq (free, fast, no credit card) ---
# Get a free key at https://console.groq.com
# [REQUIRED if LLM_PROVIDER=groq]
GROQ_API_KEY=

# Groq model to use (see https://console.groq.com/docs/models)
# Default: llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic (paid, premium quality) ---
# [REQUIRED if LLM_PROVIDER=anthropic]
# ANTHROPIC_API_KEY=

# --- Ollama (free, local inference) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Host to bind the FastAPI server
# Default: 0.0.0.0 (all interfaces, needed for Docker/Railway)
# HOST=0.0.0.0

# Port to listen on
# Default: 8000 (Railway/Render override with PORT env var)
# PORT=8000

# Enable auto-reload on code changes (dev only!)
# Default: false
# RELOAD=false

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================

# Comma-separated list of allowed origins.
# Use "*" to allow all origins (development).
# For production, set to your frontend URL(s).
# Examples:
#   CORS_ORIGINS=https://ghosttrace.up.railway.app
#   CORS_ORIGINS=https://your-app.onrender.com,http://localhost:5173
# Default: * (all origins)
# CORS_ORIGINS=*

# =============================================================================
# RATE LIMITING
# =============================================================================

# Maximum requests per minute per IP (applied globally).
# The /run endpoint (LLM-intensive) has a separate lower limit.
# Default: 60
# RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# UPLOAD LIMITS
# =============================================================================

# Maximum upload file size in MB
# Default: 10
# MAX_UPLOAD_SIZE_MB=10

# =============================================================================
# PATHS
# =============================================================================

# Directory for persisted case JSON files
# Default: ./cases
# CASES_DIR=./cases

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# Log format: "json" for structured logs (production), "readable" for dev
# Default: json
# LOG_FORMAT=json
